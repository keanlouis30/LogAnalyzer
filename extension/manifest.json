{
  "manifest_version": 3,
  "name": "Wazuh Log Analyzer",
  "version": "1.0.0",
  "description": "AI-assisted, privacy-first log analysis for SOC analysts. Summarizes Wazuh query results using a self-hosted SLM.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Wazuh Log Analyzer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' 'unsafe-inline';"
  }
}
